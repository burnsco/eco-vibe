---
import { Leaf, Menu, X } from 'lucide-react';
import CartButton from './CartButton.jsx';

const links = [
  { to: '/', label: 'Home' },
  { to: '/shop', label: 'Shop' },
  { to: '/mission', label: 'Mission' },
  { to: '/journal', label: 'Journal' },
];

const currentPath = Astro.url.pathname;

function isPathActive(to: string) {
  return currentPath === to || (to !== '/' && currentPath.startsWith(to));
}
---

<header class="glass sticky top-0 z-50 border-b border-forest-900/5 shadow-soft">
  <nav class="mx-auto flex w-full max-w-7xl items-center justify-between px-5 py-5 md:px-10">
    <button
      id="mobile-menu-toggle"
      class="rounded-full p-2 text-forest-700 transition hover:bg-sand-200 md:hidden"
      type="button"
      aria-label="Toggle navigation"
    >
      <Menu id="menu-icon" size={21} />
      <X id="close-icon" size={21} className="hidden" />
    </button>

    <div class="hidden items-center gap-10 md:flex">
      {links.map((link) => (
        <a
          href={link.to}
          class={`relative font-sans text-xs font-bold uppercase tracking-[0.2em] transition-colors duration-300 before:absolute before:-bottom-1 before:left-0 before:h-px before:w-full before:origin-right before:scale-x-0 before:bg-forest-900 before:transition-transform before:duration-300 hover:before:origin-left hover:before:scale-x-100 ${isPathActive(link.to) ? 'text-forest-900 before:scale-x-100' : 'text-forest-500/80 hover:text-forest-900'}`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <a
      href="/"
      class="flex items-center gap-2.5 text-3xl font-medium tracking-tight text-forest-900 transition-transform duration-500 hover:scale-105"
    >
      <Leaf className="text-fern-500 drop-shadow-sm" size={28} />
      Eco<span class="text-fern-600">Vibe</span>
    </a>

    <CartButton client:load />
  </nav>

  <div id="mobile-menu" class="hidden border-t border-sand-200 bg-sand-100 px-5 py-4 md:hidden">
    <div class="flex flex-col gap-3 text-sm uppercase tracking-[0.2em]">
      {links.map((link) => (
        <a
          href={link.to}
          class={`transition-colors ${isPathActive(link.to) ? 'text-forest-800' : 'text-forest-600 hover:text-forest-900'}`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (toggle && menu && menuIcon && closeIcon) {
      toggle.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        if (isOpen) {
          menu.classList.add('hidden');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        } else {
          menu.classList.remove('hidden');
          menuIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
        }
      });
    }
  }

  // Setup on initial load
  setupMobileMenu();

  // Setup on view transitions
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
