---
import { Image } from 'astro:assets';
import { ArrowRight, Droplets, Leaf, Sun, Wind } from 'lucide-react';
import heroJungle from '../assets/images/hero-jungle.png';

const trustBadges = [
  { icon: Wind, label: 'Carbon Neutral', color: 'text-fern-600' },
  { icon: Droplets, label: 'Water Conscious', color: 'text-clay-500' },
  { icon: Sun, label: 'Solar Powered', color: 'text-honey-500' },
];
---

<section class="relative overflow-hidden px-5 pb-20 pt-12 md:px-10 md:pb-24 lg:pt-20">
  <div class="pointer-events-none absolute left-[10%] top-6 h-40 w-40 rounded-full bg-fern-200/50 blur-3xl" />
  <div class="pointer-events-none absolute bottom-0 right-[8%] h-44 w-44 rounded-full bg-clay-200/60 blur-3xl" />

  <div class="mx-auto grid max-w-7xl items-center gap-16 lg:grid-cols-2">
    <div class="reveal-up relative z-10">
      <h1 class="mb-8 text-6xl font-light leading-[0.95] tracking-tight text-forest-900 md:text-8xl">
        Live lightly <br />
        on <span class="italic text-fern-600">the earth.</span>
      </h1>
      <p class="mb-12 max-w-lg font-sans text-xl leading-relaxed text-forest-600/90">
        Curated essentials crafted from renewable materials. Less waste,
        more intention, and design that feels as good as it looks.
      </p>

      <div class="mb-16 flex flex-wrap gap-5">
        <a
          href="/shop"
          class="group inline-flex items-center gap-3 rounded-full bg-forest-900 px-8 py-4 font-sans text-xs font-bold uppercase tracking-[0.25em] !text-sand-50 shadow-soft transition-all duration-300 hover:bg-forest-800 hover:shadow-premium"
        >
          Start Shopping
          <ArrowRight
            size={18}
            className="transition-transform duration-300 group-hover:translate-x-1.5"
          />
        </a>
        <a
          href="/mission"
          class="inline-flex items-center rounded-full border border-forest-900/10 bg-forest-900/5 px-8 py-4 font-sans text-xs font-bold uppercase tracking-[0.25em] text-forest-900 transition-all duration-300 hover:bg-white hover:border-forest-900/20"
        >
          Learn More
        </a>
      </div>

      <div class="grid max-w-md grid-cols-3 gap-6 border-t border-forest-900/10 pt-10">
        {trustBadges.map((badge) => {
          const Icon = badge.icon;
          return (
            <div class="text-center">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-sand-100 shadow-sm transition-transform hover:scale-110">
                <Icon size={20} className={badge.color} />
              </div>
              <p class="font-sans text-[10px] font-bold uppercase leading-tight tracking-[0.2em] text-forest-800">
                {badge.label}
              </p>
            </div>
          );
        })}
      </div>
    </div>

    <div class="reveal-up relative [animation-delay:200ms]">
      <div class="relative mx-auto aspect-[4/5] max-w-xl">
        <div class="absolute inset-0 rotate-[8deg] rounded-[40%] bg-sand-100 ring-1 ring-forest-900/5 shadow-premium" />
        <div class="absolute inset-0 -rotate-[5deg] rounded-[43%] bg-fern-100/40 ring-1 ring-forest-900/5 shadow-soft" />

        <Image
          src={heroJungle}
          alt="Lush green jungle with a gentle waterfall"
          class="relative z-10 h-full w-full rounded-[4rem] object-cover shadow-premium transition-transform duration-700 hover:scale-[1.02]"
          loading="eager"
        />

        <div class="float-slow absolute -bottom-8 -left-8 z-20 flex items-center gap-4 rounded-3xl border border-white/40 bg-white/80 p-5 shadow-premium backdrop-blur-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-fern-100 text-fern-700 shadow-inner">
            <Leaf size={24} />
          </div>
          <div>
            <p class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-forest-500">
              Impact
            </p>
            <p class="text-xl font-semibold text-forest-900">
              10,000+ Trees
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
